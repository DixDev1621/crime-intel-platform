// Crime Intelligence AI Platform — Database Schema
// Karnataka State Police — Conversational Crime Analytics Platform
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------------
// ENUMS
// ------------------------------------------------------------------

enum Role {
  ADMIN
  INVESTIGATOR
  ANALYST
  SUPERVISOR
  POLICY_MAKER
}

enum FIRStatus {
  OPEN
  UNDER_INVESTIGATION
  CHARGESHEET_FILED
  CLOSED
  ACQUITTED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum EvidenceType {
  DOCUMENT
  PHOTO
  VIDEO
  AUDIO
  PHYSICAL
  DIGITAL
  FORENSIC
}

enum RelationshipType {
  ASSOCIATE
  FAMILY
  FINANCIAL
  CO_ACCUSED
  VICTIM_ACCUSED
  ORGANIZATION_MEMBER
  INVOLVED_IN
  CHARGED_IN
  REPORTED_IN
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

// ------------------------------------------------------------------
// GEOGRAPHY
// ------------------------------------------------------------------

model State {
  id        String     @id @default(uuid())
  name      String     @unique
  code      String     @unique
  districts District[]
  createdAt DateTime   @default(now())
}

model District {
  id             String          @id @default(uuid())
  name           String
  state          State           @relation(fields: [stateId], references: [id])
  stateId        String
  policeStations PoliceStation[]
  crimes         Crime[]
  hotspots       Hotspot[]
  createdAt      DateTime        @default(now())

  @@unique([name, stateId])
}

model PoliceStation {
  id           String    @id @default(uuid())
  name         String
  code         String    @unique
  district     District  @relation(fields: [districtId], references: [id])
  districtId   String
  latitude     Float?
  longitude    Float?
  firs         FIR[]
  users        User[]
  createdAt    DateTime  @default(now())
}

// ------------------------------------------------------------------
// USERS & AUDIT
// ------------------------------------------------------------------

model User {
  id              String         @id @default(uuid())
  badgeNumber     String         @unique
  fullName        String
  email           String         @unique
  passwordHash    String
  role            Role
  policeStation   PoliceStation? @relation(fields: [policeStationId], references: [id])
  policeStationId String?
  preferredLang   String         @default("en")
  isActive        Boolean        @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  firsCreated     FIR[]          @relation("FIRCreatedBy")
  investigations  Investigation[]
  auditLogs       AuditLog[]
  chatSessions    ChatSession[]
}

model AuditLog {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  action     String
  entityType String
  entityId   String?
  ipAddress  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

// ------------------------------------------------------------------
// CRIME CORE ENTITIES
// ------------------------------------------------------------------

model CrimeType {
  id          String  @id @default(uuid())
  name        String  @unique
  category    String
  severity    Int     @default(1) // 1 (minor) - 5 (severe)
  ipcSections String[]
  crimes      Crime[]
  predictions CrimePrediction[]
}

model Crime {
  id             String     @id @default(uuid())
  fir            FIR?       @relation(fields: [firId], references: [id])
  firId          String?    @unique
  crimeType      CrimeType  @relation(fields: [crimeTypeId], references: [id])
  crimeTypeId    String
  district       District   @relation(fields: [districtId], references: [id])
  districtId     String
  latitude       Float?
  longitude      Float?
  occurredAt     DateTime
  description    String
  createdAt      DateTime   @default(now())
}

model FIR {
  id              String        @id @default(uuid())
  firNumber       String        @unique
  policeStation   PoliceStation @relation(fields: [policeStationId], references: [id])
  policeStationId String
  status          FIRStatus     @default(OPEN)
  summary         String
  filedAt         DateTime      @default(now())
  createdBy       User          @relation("FIRCreatedBy", fields: [createdById], references: [id])
  createdById     String

  crime           Crime?
  victims         VictimOnFIR[]
  accused         AccusedOnFIR[]
  evidence        Evidence[]
  investigations  Investigation[]
  financialTx     FinancialTransaction[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([filedAt])
}

model Victim {
  id          String        @id @default(uuid())
  fullName    String
  gender      Gender        @default(UNKNOWN)
  age         Int?
  address     String?
  phone       String?
  firs        VictimOnFIR[]
  createdAt   DateTime      @default(now())
}

model VictimOnFIR {
  fir      FIR    @relation(fields: [firId], references: [id])
  firId    String
  victim   Victim @relation(fields: [victimId], references: [id])
  victimId String

  @@id([firId, victimId])
}

model Accused {
  id              String          @id @default(uuid())
  fullName        String
  aliases         String[]
  gender          Gender          @default(UNKNOWN)
  age             Int?
  address         String?
  phone           String?
  photoUrl        String?
  fingerprintRef  String?
  riskScore       Float           @default(0) // 0-100, computed by offender profiling
  behaviorProfile String?
  firs            AccusedOnFIR[]
  createdAt       DateTime        @default(now())
}

model AccusedOnFIR {
  fir        FIR     @relation(fields: [firId], references: [id])
  firId      String
  accused    Accused @relation(fields: [accusedId], references: [id])
  accusedId  String

  @@id([firId, accusedId])
}

model Relationship {
  id           String           @id @default(uuid())
  sourceType   String // "accused" | "victim" | "organization" | "account" | "vehicle" | "phone"
  sourceId     String
  targetType   String
  targetId     String
  relationType RelationshipType
  strength     Float            @default(1)
  notes        String?
  createdAt    DateTime         @default(now())

  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
}

// ------------------------------------------------------------------
// EVIDENCE & INVESTIGATION
// ------------------------------------------------------------------

model Evidence {
  id          String       @id @default(uuid())
  fir         FIR          @relation(fields: [firId], references: [id])
  firId       String
  type        EvidenceType
  title       String
  description String?
  fileUrl     String?
  collectedAt DateTime     @default(now())
  createdAt   DateTime     @default(now())
}

model Investigation {
  id           String   @id @default(uuid())
  fir          FIR      @relation(fields: [firId], references: [id])
  firId        String
  investigator User     @relation(fields: [investigatorId], references: [id])
  investigatorId String
  stage        String
  notes        String?
  aiSummary    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ------------------------------------------------------------------
// FINANCIAL CRIME
// ------------------------------------------------------------------

model FinancialTransaction {
  id            String   @id @default(uuid())
  fir           FIR      @relation(fields: [firId], references: [id])
  firId         String
  fromAccount   String
  toAccount     String
  amount        Float
  currency      String   @default("INR")
  transactedAt  DateTime
  flagged       Boolean  @default(false)
  flagReason    String?
  createdAt     DateTime @default(now())
}

// ------------------------------------------------------------------
// AI / PREDICTIVE
// ------------------------------------------------------------------

model Hotspot {
  id           String   @id @default(uuid())
  district     District @relation(fields: [districtId], references: [id])
  districtId   String
  latitude     Float
  longitude    Float
  intensity    Float // 0-1
  windowStart  DateTime
  windowEnd    DateTime
  createdAt    DateTime @default(now())
}

model CrimePrediction {
  id              String    @id @default(uuid())
  crimeType       CrimeType @relation(fields: [crimeTypeId], references: [id])
  crimeTypeId     String
  districtId      String
  predictedFor    DateTime
  confidenceScore Float
  reasoning       String
  evidenceRefs    Json?
  createdAt       DateTime  @default(now())
}

// ------------------------------------------------------------------
// CONVERSATIONAL AI
// ------------------------------------------------------------------

model ChatSession {
  id        String        @id @default(uuid())
  user      User          @relation(fields: [userId], references: [id])
  userId    String
  title     String        @default("New conversation")
  language  String        @default("en")
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatMessage {
  id        String      @id @default(uuid())
  session   ChatSession @relation(fields: [sessionId], references: [id])
  sessionId String
  role      ChatRole
  content   String
  citations Json?
  createdAt DateTime    @default(now())
}
